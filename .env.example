# ─── IEDB3.0 API Auth (Cycle Time module) ───────────────────────────────────
# OAuth 2.0 client_credentials flow against Okta.
#
# IEDB_CLIENT_KEY = base64( <client_id>:<client_secret> )
# Same value the previous .NET service used under appsettings.json → IEDB:Key.
#
# Tokens are fetched automatically from:
#   https://jabil.okta.com/oauth2/default/v1/token
# and cached in-process. They refresh ~60s before expiry — no manual paste.

IEDB_CLIENT_KEY=PASTE_BASE64_CLIENT_KEY_HERE
